# Copy this file to .env and set your real values.
# Docker Compose and many tools load .env automatically.
# Do not commit .env (it is in .gitignore).

# --- Required for AI agents (Zoey, math checker) ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Optional: Leave Request Workflow – send real emails via Gmail ---
# If not set, leave emails are only printed to the console.
# GMAIL_FROM=your.gmail@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
# SEND_LEAVE_EMAILS_VIA_GMAIL=1

# --- Optional: URL used in the manager approval email (for the curl examples) ---
# LEAVE_BASE_URL=http://localhost:9999

# --- Optional: How long (seconds) to wait for manager reply before returning TIMEOUT (default 600) ---
# LEAVE_WAIT_TIMEOUT_SECONDS=600

# --- Optional: YouTube converter workflow – output directory for downloaded/converted files ---
# CONVERTER_OUTPUT_DIR=./data/converter_output
