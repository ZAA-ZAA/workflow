# Copy this file to .env and set your real values.
# Docker Compose and many tools load .env automatically.
# Do not commit .env (it is in .gitignore).

# --- Required for AI agents (Zoey, math checker) ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Optional: Leave Request Workflow – send real emails via Gmail ---
# If not set, leave emails are only printed to the console.
# GMAIL_FROM=your.gmail@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
# SEND_LEAVE_EMAILS_VIA_GMAIL=1

# --- Optional: URL used in the manager approval email (for the curl examples) ---
# LEAVE_BASE_URL=http://localhost:9999

# --- Optional: Enable Gmail inbox intake workers for leave emails (default enabled) ---
# ENABLE_GMAIL_LEAVE_INTAKE=1

# --- Optional: Gmail inbox polling interval in seconds for intake worker ---
# LEAVE_GMAIL_POLL_SECONDS=20

# --- Optional: On first run, ignore historical inbox emails and start from latest ---
# Prevents processing old unrelated mail/history when enabling Gmail intake.
# LEAVE_GMAIL_SKIP_EXISTING_ON_FIRST_RUN=1

# --- Optional: IMAP timeout seconds for Gmail reads ---
# LEAVE_GMAIL_IMAP_TIMEOUT_SECONDS=20

# --- Optional (test mode): allow one sender email to act as multiple employees ---
# 0 = strict (default), 1 = allow Employee ID in email to override sender mapping
# LEAVE_ALLOW_SHARED_EMPLOYEE_EMAILS=0

# --- Optional: Email -> Task Extractor Gmail API (OAuth mode) ---
# EMAIL_TASK_GMAIL_CREDENTIALS_FILE=/app/credentials.json
# EMAIL_TASK_GMAIL_TOKEN_FILE=/app/data/gmail_token.json
# EMAIL_TASK_GMAIL_QUERY=newer_than:7d
# EMAIL_TASK_GMAIL_USER_ID=me
